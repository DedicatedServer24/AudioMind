# OpenAI API Key (erforderlich) — muss mit "sk-" beginnen.
# Key erstellen: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Max. Upload-Größe in MB (Default: 500).
# Muss konsistent zu .streamlit/config.toml -> server.maxUploadSize sein.
# STREAMLIT_MAX_UPLOAD_SIZE=500

# Optional: Pfad zur SQLite-Datenbank (Default: data/audiomind.db).
# In Docker-Deployments auf das gemountete Volume zeigen lassen.
# AUDIOMIND_DB_PATH=data/audiomind.db
